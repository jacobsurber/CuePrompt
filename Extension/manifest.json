{
  "manifest_version": 3,
  "name": "CuePrompt Companion",
  "version": "1.0.0",
  "description": "Sends Google Slides speaker notes to CuePrompt for voice-tracked teleprompting.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://docs.google.com/presentation/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/presentation/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
